# ============================================================
# Inventra Backend — Environment Variables
# Copy this to .env and fill in all values before running.
# NEVER commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database (PostgreSQL) ─────────────────────────────────────
# Railway: auto-provided as DATABASE_URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/inventra

# ── JWT Secrets (generate with: openssl rand -hex 64) ────────
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING_openssl_rand_hex_64
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AES-256 Encryption Key (exactly 32 chars or any length) ──
# Used for encrypting PII: GSTIN, phone, email, address, etc.
# Generate: openssl rand -hex 32
ENCRYPT_KEY=REPLACE_WITH_32_CHAR_ENCRYPTION_KEY_FOR_AES256
FINANCIAL_ENCRYPT_KEY=YOUR_RANDOM_32_PLUS_CHARACTER_KEY

# ── Frontend URL (CORS) ───────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── SMTP (optional — for email notifications) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Inventra <noreply@inventra.app>

# ── Cloudinary (optional — for file uploads) ─────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Super Admin (seed script only) ───────────────────────────
SUPER_ADMIN_PASSWORD=Inventra@SuperAdmin123
